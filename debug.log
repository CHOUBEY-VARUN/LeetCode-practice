 key.size();\\n        int have = 0;\\n        Map<Character,Integer> str = new HashMap<>();\\n        int left = 0;\\n        int start = 0;\\n        int len = Integer.MAX_VALUE;\\n        for(int right = 0; right < s.length(); right++){\\n            char c = s.charAt(right);\\n            str.put(c,str.getOrDefault(c,0)+1);\\n            if(key.containsKey(c)){\\n                if(str.get(c).equals(key.get(c))){\\n                    have++;\\n                }\\n                    while(have == need){\\n                        if(right - left +1 < len){\\n                            len = right - left +1;\\n                            start = left;\\n                        }\\n                        str.put(s.charAt(left),str.get(s.charAt(left))-1);\\n                        if(key.containsKey(s.charAt(left))){\\n                            if(str.get(s.charAt(left)) < key.get(s.charAt(left))){\\n                                have--;\\n                            }\\n                        }\\n                        left++;\\n                        }\\n                }\\n            }\\n        return len == Integer.MAX_VALUE ? \\"\\" : s.substring(start, start + len);\\n        }\\n    }\\n","compare_result":"1111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"minimum-window-substring","has_notes":false,"flag_type":1,"frontend_id":469},{"id":1907364067,"question_id":424,"lang":"java","lang_name":"Java","time":"5\xc2\xa0months","timestamp":1770168851,"status":10,"status_display":"Accepted","runtime":"27 ms","url":"/submissions/detail/1907364067/","is_pending":"Not Pending","title":"Longest Repeating Character Replacement","memory":"47.4 MB","code":"class Solution {\\n    public int characterReplacement(String s, int k) {\\n        Map<Character,Integer> map = new HashMap<>();\\n        int left = 0;\\n        int ans = 0;\\n        int max = 0;\\n        for(int right = 0; right < s.length(); right++){\\n                int window = right-left+1;\\n                char c = s.charAt(right);\\n                map.put(c,map.getOrDefault(c,0)+1);\\n                max = Math.max(max,map.get(c));\\n                while(window - max > k && left<s.length()){\\n                    map.put(s.charAt(left),map.get(s.charAt(left))-1);\\n                    left++;\\n                    window = right-left+1;\\n                }\\n                ans = Math.max(ans,window);\\n        }\\n        return ans;\\n    }\\n}","compare_result":"11111111111111111111111111111111111111111111111111","title_slug":"longest-repeating-character-replacement","has_notes":false,"flag_type":1,"frontend_id":468},{"id":1907359512,"question_id":424,"lang":"java","lang_name":"Java","time":"5\xc2\xa0months","timestamp":1770168221,"status":20,"status_display":"Compile Error","runtime":"N/A","url":"/submissions/detail/1907359512/","is_pending":"Not Pending","title":"Longest Repeating Character Replacement","memory":"N/A","code":"class Solution {\\n    public int characterReplacement(String s, int k) {\\n        Map<Character,Integer> map = new HashMap<>();\\n        int left = 0;\\n        int ans = 0;\\n        int max = 0;\\n        for(int right = 0; right < s.length(); right++){\\n            while(window - max <= k){\\n                int window = right-left+1;\\n                char c = s.charAt(right);map.put(c,map.getOrDefault(c,0)+1);\\n            max = Math.max(max,map.get(c));\\n            }\\n        }\\n    }\\n}","compare_result":null,"title_slug":"longest-repeating-character-replacement","has_notes":false,"flag_type":1,"frontend_id":467},{"id":1906533284,"question_id":5,"lang":"java","lang_name":"Java","time":"5\xc2\xa0months","timestamp":1770112101,"status":10,"status_display":"Accepted","runtime":"17 ms