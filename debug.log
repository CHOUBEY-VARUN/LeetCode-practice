          if(curr.right!=null)stack.addFirst(curr.right);\\n                level.add(curr.val);\\n                size--;\\n            }\\n            result.add(level);\\n        }\\n        return result;\\n    }\\n}","compare_result":"11111111111111111111111111111111111","title_slug":"binary-tree-level-order-traversal","has_notes":false,"flag_type":1,"frontend_id":822},{"id":2047430814,"question_id":235,"lang":"java","lang_name":"Java","time":"1\xc2\xa0week","timestamp":1782536833,"status":10,"status_display":"Accepted","runtime":"6 ms","url":"/submissions/detail/2047430814/","is_pending":"Not Pending","title":"Lowest Common Ancestor of a Binary Search Tree","memory":"47.8 MB","code":"/**\\n * Definition for a binary tree node.\\n * public class TreeNode {\\n *     int val;\\n *     TreeNode left;\\n *     TreeNode right;\\n *     TreeNode(int x) { val = x; }\\n * }\\n */\\n\\nclass Solution {\\n    public TreeNode lowestCommonAncestor(TreeNode root, TreeNode p, TreeNode q) {\\n        if(p.val > root.val && q.val > root.val)return lowestCommonAncestor(root.right,p,q);\\n        if(p.val < root.val && q.val < root.val)return lowestCommonAncestor(root.left,p,q);\\n\\n        return root;\\n        \\n    }\\n}","compare_result":"111111111111111111111111111111","title_slug":"lowest-common-ancestor-of-a-binary-search-tree","has_notes":false,"flag_type":1,"frontend_id":821},{"id":2047411875,"question_id":572,"lang":"java","lang_name":"Java","time":"1\xc2\xa0week","timestamp":1782535478,"status":10,"status_display":"Accepted","runtime":"2 ms","url":"/submissions/detail/2047411875/","is_pending":"Not Pending","title":"Subtree of Another Tree","memory":"46.6 MB","code":"/**\\n * Definition for a binary tree node.\\n * public class TreeNode {\\n *     int val;\\n *     TreeNode left;\\n *     TreeNode right;\\n *     TreeNode() {}\\n *     TreeNode(int val) { this.val = val; }\\n *     TreeNode(int val, TreeNode left, TreeNode right) {\\n *         this.val = val;\\n *