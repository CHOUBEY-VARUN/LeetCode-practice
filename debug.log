nt n : map.keySet()){\\n            q.add(n);\\n            if(q.size() > k){\\n                q.poll();\\n            }\\n        }\\n        int[] ans = new int[k];\\n        for(int i = 0; i<k; i++){\\n            ans[i] = q.poll();\\n        }\\n        return ans;\\n    }\\n}","compare_result":"11111111111111111111111","title_slug":"top-k-frequent-elements","has_notes":false,"flag_type":1,"frontend_id":352},{"id":1849774686,"question_id":11,"lang":"java","lang_name":"Java","time":"6\xc2\xa0months, 3\xc2\xa0weeks","timestamp":1765166174,"status":10,"status_display":"Accepted","runtime":"5 ms","url":"/submissions/detail/1849774686/","is_pending":"Not Pending","title":"Container With Most Water","memory":"76.6 MB","code":"class Solution {\\n    public int maxArea(int[] height) {\\n        int left = 0;\\n        int right = height.length - 1;\\n        int maxArea = 0;\\n        while(left < right){\\n            int area = Math.min(height[left],height[right])*(right-left);\\n            maxArea = Math.max(maxArea,area);\\n            if(height[left] < height[right]){left++;}else{right--;}\\n        }\\n        return maxArea;\\n    }\\n}","compare_result":"11111111111111111111111111111111111111111111111111111111111111111","title_slug":"container-with-most-water","has_notes":false,"flag_type":1,"frontend_id":351},{"id":1848002335,"question_id":121,"lang":"java","lang_name":"Java","time":"6\xc2\xa0months, 4\xc2\xa0weeks","timestamp":1764987684,"status":10,"status_display":"Accepted","runtime":"1 ms","url":"/submissions/detail/1848002335/","is_pending":"Not Pending","title":"Best Time to Buy and Sell Stock","memory":"94.6 MB","code":"class Solution {\\n    public int maxProfit(int[] prices) {\\n        int buy = 0;\\n        int sell = 0;\\n        int maxProfit = 0;\\n        for(int i = 0; i<prices.length;i++){\\n            if(prices[i] < prices[buy]){buy = i;}\\n            int profit = prices[i] - prices[buy];\\n            if(profit > maxProfit){\\n          