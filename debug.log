54869,"status":10,"status_display":"Accepted","runtime":"7 ms","url":"/submissions/detail/1908549403/","is_pending":"Not Pending","title":"Longest Repeating Character Replacement","memory":"46.4 MB","code":"class Solution {\\n    public int characterReplacement(String s, int k) {\\n        int left = 0;\\n        int max = 0;\\n        int ans = 0;\\n        int[] freq = new int[26];\\n        for(int right = 0;right<s.length();right++){\\n            char c = s.charAt(right);\\n            freq[c-\'A\']++;\\n            max = Math.max(max,freq[c-\'A\']);\\n            while((right-left+1)-max > k){\\n                char leftc = s.charAt(left);\\n                freq[leftc-\'A\']--;\\n                left++;\\n            }   \\n            ans = Math.max(ans,right-left+1);\\n        }\\n        return ans;\\n    }\\n}","compare_result":"11111111111111111111111111111111111111111111111111","title_slug":"longest-repeating-character-replacement","has_notes":false,"flag_type":1,"frontend_id":479}],"has_next":true,"last_key":""}'
