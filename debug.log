5.6 MB","code":"class Solution {\\n    public int[] productExceptSelf(int[] nums) {\\n        int zeroes = 0;\\n        int product = 1;\\n        int[] ans = new int[nums.length];\\n        for(int i = 0; i<nums.length; i++){\\n            if(nums[i] == 0){zeroes++;}else{product*=nums[i];}\\n        }\\n\\n        if(zeroes>1)return new int[nums.length];\\n        if(zeroes==1){\\n            for(int i = 0; i<nums.length; i++){\\n                if(nums[i] == 0){\\n                    ans[i] = product;\\n                    }else{\\n                        ans[i] = 0;\\n                        }\\n                        }\\n            \\n            }\\n            if(zeroes < 1){\\n                for(int i = 0; i<nums.length; i++){\\n                    ans[i] = product/nums[i];\\n                    }\\n                    }\\n\\n            return ans;\\n    }\\n}","compare_result":"111111111111111111111111","title_slug":"product-of-array-except-self","has_notes":false,"flag_type":1,"frontend_id":102},{"id":1814889304,"question_id":4068,"lang":"java","lang_name":"Java","time":"8\xc2\xa0months","timestamp":1761731066,"status":10,"status_display":"Accepted","runtime":"3 ms","url":"/submissions/detail/1814889304/","is_pending":"Not Pending","title":"Sum of Elements With Frequency Divisible by K","memory":"43.4 MB","code":"class Solution {\\n    public int sumDivisibleByK(int[] nums, int k) {\\n        Map<Integer,Integer> map =new HashMap<>();\\n        Set<Integer> set = new HashSet<>();\\n        for(int i = 0; i<nums.length; i++){\\n            map.put(nums[i],map.getOrDefault(nums[i],0)+1);\\n            set.add(nums[i]);\\n        }\\n        int ans = 0;\\n        for(int n : map.keySet()){\\n            if(map.get(n)%k == 0){ans += n*map.get(n);}\\n        }\\n        return ans;\\n    }\\n}","compare_result":"","title_slug":"sum-of-elements-with-frequency-divisible-by-k","has_notes":false,"flag_type":1,"frontend_id":101},{"id":1814541184,"question_id":41