itle":"Longest Consecutive Sequence","memory":"N/A","code":"class Solution {\\n    public int longestConsecutive(int[] nums) {\\n        if(nums.length == 0)return 0;\\n        Set<Integer> set = new HashSet<>();\\n        for(int n : nums){set.add(n);}\\n        int count = 1, result = 1;\\n        for(int n : nums){\\n            int curr = n;\\n            if(set.contains(curr - 1))continue;\\n            while(set.contains(curr + 1)){\\n                count++;\\n                result = Math.max(result,count);\\n                curr++;\\n            }\\n            count = 1;\\n        }\\n        return result;\\n    }\\n}","compare_result":"11111111111111111111111111111111111111111111111111111111111111111111111111111110000","title_slug":"longest-consecutive-sequence","has_notes":false,"flag_type":1,"frontend_id":230},{"id":1826836873,"question_id":128,"lang":"java","lang_name":"Java","time":"7\xc2\xa0months, 3\xc2\xa0weeks","timestamp":1762860439,"status":11,"status_display":"Wrong Answer","runtime":"N/A","url":"/submissions/detail/1826836873/","is_pending":"Not Pending","title":"Longest Consecutive Sequence","memory":"N/A","code":"class Solution {\\n    public int longestConsecutive(int[] nums) {\\n        Set<Integer> set = new HashSet<>();\\n        for(int n : nums){set.add(n);}\\n        int count = 1, result = 1;\\n        for(int n : nums){\\n            int curr = n;\\n            if(set.contains(curr - 1))continue;\\n            while(set.contains(curr + 1)){\\n                count++;\\n                result = Math.max(result,count);\\n                curr++;\\n            }\\n            count = 1;\\n        }\\n        return result;\\n    }\\n}","compare_result":"11101111111111111111111111111111111111111111111111111111111111111111111111111110000","title_slug":"longest-consecutive-sequence","has_notes":false,"flag_type":1,"frontend_id":229},{"id":1826828301,"question_id":128,"lang":"java","lang_name":"Java","time":"7\xc2\xa0months, 3\xc2\xa0weeks