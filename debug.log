se-linked-list","has_notes":false,"flag_type":1,"frontend_id":791},{"id":2036317554,"question_id":76,"lang":"java","lang_name":"Java","time":"2\xc2\xa0weeks, 2\xc2\xa0days","timestamp":1781696513,"status":10,"status_display":"Accepted","runtime":"2 ms","url":"/submissions/detail/2036317554/","is_pending":"Not Pending","title":"Minimum Window Substring","memory":"45.5 MB","code":"class Solution {\\n    public String minWindow(String s, String t) {\\n        int start = 0;\\n        int len = 0;\\n        int need = t.length();\\n        int have = 0;\\n        int left = 0;\\n        int[] abc = new int[128];\\n        for (char c : t.toCharArray()) {\\n            abc[c]++;\\n        }\\n\\n        for (int right = 0; right < s.length(); right++) {\\n            int x = s.charAt(right);\\n            if (abc[x] > 0) {\\n                have++;\\n            }\\n            abc[x]--;\\n\\n            while (have == need) {\\n                if (len > right - left + 1 || len == 0) {\\n                    start = left;\\n                    len = right - left + 1;\\n                }\\n                char leftc = s.charAt(left);\\n                left++;\\n                if (abc[leftc] >= 0) {\\n                    have--;\\n                }\\n                abc[leftc]++;\\n            }\\n        }\\n        return s.substring(start, start + len);\\n    }\\n}","compare_result":"1111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"minimum-window-substring","has_notes":false,"flag_type":1,"frontend_id":790},{"id":2034497414,"question_id":347,"lang":"java","lang_name":"Java","time":"2\xc2\xa0weeks, 4\xc2\xa0days","timestamp":1781574080,"status":10,"status_display":"Accepted","runtime":"16 ms","url":"/submissions/detail/2034497414/","is_pending":"Not Pending","title":"Top K Frequent Elements","memory":"47.5 MB","code":"class Solution {\\n    public int[] topKFrequent(int[] nums, int k) {\\n        Map<Integer,Integer> map = new HashMap<>();\\n        int[] ans = new int[k];\\n\\n        for(int num : nums){\\n            map.put(num,map.getOrDefault(num,0)+1);\\n        }\\n\\n        PriorityQueue<Integer> q = new PriorityQueue<>((a,b)->map.get(a)-map.get(b));\\n        for(int key : map.keySet()){\\n            q.offer(key);\\n\\n            if(q.size()>k){q.poll();}\\n        }\\n        int idx = 0;\\n        while(idx < k){\\n            ans[idx] = q.poll();\\n            idx++;\\n        }\\n        return ans;\\n    }\\n}","compare_result":"11111111111111111111111","title_slug":"top-k-frequent-elements","has_notes":false,"flag_type":1,"frontend_id":789},{"id":2034025934,"question_id":169,"lang":"java","lang_name":"Java","time":"2\xc2\xa0weeks, 4\xc2\xa0days","timestamp":1781532967,"status":10,"status_display":"Accepted","runtime":"1 ms","url":"/submissions/detail/2034025934/","is_pending":"Not Pending","title":"Majority Element","memory":"55.9 MB","code":"class Solution {\\n    public int majorityElement(int[] nums) {\\n        int count = 1;\\n        int ans = nums[0];\\n\\n        for (int num : nums) {\\n            if (num == ans) {\\n                count++;\\n            } else {\\n                count--;\\n                if (count <= 0) {\\n                    ans = num;\\n                    count = 1;\\n                }\\n            }\\n        }\\n        return ans;\\n    }\\n}","compare_result":"11111111111111111111111111111111111111111111111111111","title_slug":"majority-element","has_notes":false,"flag_type":1,"frontend_id":788},{"id":2033466944,"question_id":169,"lang":"java","lang_name":"Java","time":"2\xc2\xa0weeks, 5\xc2\xa0days","timestamp":1781500510,"status":10,"status_display":"Accepted","runtime":"1 ms","url":"/submissions/detail/2033466944/","is_pending":"Not Pending