   if (nums[i] != nums[i - 1]) {\\n                nums[k++] = nums[i];\\n            }\\n        }\\n\\n        // Step 2: count hills and valleys on the compressed array of length k\\n        int count = 0;\\n        for (int i = 1; i < k - 1; i++) {\\n            if ((nums[i] > nums[i - 1] && nums[i] > nums[i + 1]) ||\\n                (nums[i] < nums[i - 1] && nums[i] < nums[i + 1])) {\\n                count++;\\n            }\\n        }\\n\\n        return count;\\n    }\\n}\\n","compare_result":"1111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"count-hills-and-valleys-in-an-array","has_notes":false,"flag_type":1,"frontend_id":379}],"has_next":true,"last_key":""}'
