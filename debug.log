memory":"59.2 MB","code":"class Solution {\\n    public List<List<Integer>> threeSum(int[] nums) {\\n        List<List<Integer>> list = new ArrayList<>();\\n        Arrays.sort(nums);\\n     for(int i = 0; i<nums.length-2; i++){\\n        if(i > 0 && nums[i] == nums[i-1])continue;\\n        int curr = nums[i];\\n        int diff = 0 - curr;\\n        int left = i+1; int right = nums.length - 1;\\n        while(left < right){\\n            int a = nums[left];\\n            int b = nums[right];\\n            int sum = a+b;\\n            if(sum == diff){\\n                list.add(Arrays.asList(curr,a,b));\\n                left++;\\n                right--;\\n                while(left<right && nums[left] == nums[left -1])left++;\\n                while(left<right && nums[right] == nums[right + 1])right--;\\n                }\\n            if(sum < diff){left++;}\\n            if(sum > diff){right--;}\\n        }\\n        while(left < right){\\n            int a = nums[left];\\n            int b = nums[right];\\n            int sum = a+b;\\n            if(sum == diff){\\n                list.add(Arrays.asList(curr,a,b));left++;right--;\\n                }\\n            if(nums[left] == nums[left -1])left++;\\n            if(nums[right] == nums[right + 1])right--;\\n            if(sum < diff){left++;}\\n            if(sum > diff){right--;}\\n        }\\n     }\\n     return list;   \\n    }\\n}","compare_result":"","title_slug":"3sum","has_notes":false,"flag_type":1,"frontend_id":260},{"id":1830006438,"question_id":11,"lang":"java","lang_name":"Java","time":"7\xc2\xa0months, 2\xc2\xa0weeks","timestamp":1763170732,"status":10,"status_display":"Accepted","runtime":"5 ms","url":"/submissions/detail/1830006438/","is_pending":"Not Pending","title":"Container With Most Water","memory":"77.1 MB","code":"class Solution {\\n    public int maxArea(int[] height) {\\n        int left = 0; int right = height.length - 1;\\n        int a = height[left]; int b = height[right];\\n        int maxArea = Math.min(a,b)*(right-left);\\n        while(left < right){\\n            a = height[left];\\n            b = height[right];\\n            maxArea = Math.max(maxArea,Math.min(a,b)*(right-left));\\n            if(a < b){\\n                left ++;\\n            }else{right--;}\\n        }\\n        return maxArea;\\n    }\\n}","compare_result":"11111111111111111111111111111111111111111111111111111111111111111","title_slug":"container-with-most-water","has_notes":false,"flag_type":1,"frontend_id":259}],"has_next":true,"last_key":""}'
