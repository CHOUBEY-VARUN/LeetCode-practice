"\\";\\n            }else{\\n                return s.substring(start,start+minLen);\\n                }\\n    }\\n}","compare_result":"1111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"minimum-window-substring","has_notes":false,"flag_type":1,"frontend_id":484},{"id":1908657227,"question_id":239,"lang":"java","lang_name":"Java","time":"4\xc2\xa0months, 4\xc2\xa0weeks","timestamp":1770265531,"status":10,"status_display":"Accepted","runtime":"27 ms","url":"/submissions/detail/1908657227/","is_pending":"Not Pending","title":"Sliding Window Maximum","memory":"143.5 MB","code":"class Solution {\\n    public int[] maxSlidingWindow(int[] nums, int k) {\\n        int left = 0;\\n        int[] ans = new int[nums.length-k+1];\\n        int idx = 0;\\n        Deque<Integer> q = new ArrayDeque<>();\\n        for(int right = 0; right<nums.length; right++){\\n            while(!q.isEmpty() && nums[right] >= nums[q.peekFirst()]){\\n                q.pollFirst();\\n            }\\n            q.offerFirst(right);\\n            if(right>=k-1){\\n                ans[idx] = nums[q.peekLast()];\\n                idx++;\\n                if(q.peekLast()==left){\\n                    q.pollLast();\\n                }\\n                left++;\\n            }\\n\\n        }\\n        return ans;\\n    }\\n}","compare_result":"1111111111111111111111111111111111111111111111111111","title_slug":"sliding-window-maximum","has_notes":false,"flag_type":1,"frontend_id":483},{"id":1908656937,"question_id":239,"lang":"java","lang_name":"Java","time":"4\xc2\xa0months, 4\xc2\xa0weeks","timestamp":1770265514,"status":20,"status_display":"Compile Error","runtime":"N/A","url":"/submissions/detail/1908656937/","is_pending":"Not Pending","title":"Sliding Window Maximum","mem