            left++;\\n            right--;\\n        }\\n    }\\n}","compare_result":"1111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"next-permutation","has_notes":false,"flag_type":1,"frontend_id":806},{"id":2043379101,"question_id":31,"lang":"java","lang_name":"Java","time":"1\xc2\xa0week, 3\xc2\xa0days","timestamp":1782217934,"status":11,"status_display":"Wrong Answer","runtime":"N/A","url":"/submissions/detail/2043379101/","is_pending":"Not Pending","title":"Next Permutation","memory":"N/A","code":"class Solution {\\n    public void nextPermutation(int[] nums) {\\n        for (int i = nums.length - 2; i >= 0; i--) {\\n            if (nums[i] < nums[i + 1]) {\\n                for (int j = i; j < nums.length; j++) {\\n                    if (nums[j] > nums[i]) {\\n                        int temp = nums[i];\\n                        nums[i] = nums[j];\\n                        nums[j] = temp;\\n                        reverse(nums, i + 1, nums.length - 1);\\n                        return;\\n                    }\\n                }\\n            }\\n        }\\n        reverse(nums,0,nums.length-1);\\n        return;\\n    }\\n\\n    public void reverse(int[] nums, int left, int right) {\\n        while (left < right) {\\n            int temp = nums[left];\\n            nums[left] = nums[right];\\n            nums[right] = temp;\\n            left++;\\n            right--;\\n        }\\n    }\\n}","compare_result":"1111110111110010111110101011111010011001111010110011101111010110111011000100011101111101111110110010111010011110101110110011111111010000110111111101100111011011110111001111101111011101111011011011100110111010101110101011111111111111011110010011110111111011011110101111","title_slug":"next-permutation","has_notes":false,"flag_type":1,"frontend_id":805},{"id":2041655682,"question_id":39,"lang":"java","lang_name":"Java","time":"1\xc2\xa0week, 5\xc2\xa0days","timestamp":1782105187,"status":10,"status_display":"Accepted","runtime":"2 ms","url":"/submissions/detail/2041655682/","is_pending":"Not Pending","title":"Combination Sum","memory":"45.7 MB","code":"class Solution {\\n    public List<List<Integer>> combinationSum(int[] candidates, int target) {\\n        List<Integer> path = new ArrayList<>();\\n        List<List<Integer>> result = new ArrayList<>();\\n        int sum = 0;\\n\\n        backtrack(candidates, 0, target, sum, path, result);\\n        return result;\\n    }\\n\\n    public void backtrack(int[] candidates, int start, int target, int sum, List<Integer> path, List<List<Integer>> result) {\\n        if (sum == target) {\\n            result.add(new ArrayList<>(path));\\n            return;\\n        }else if(sum > target){return;}\\n\\n        for (int i = start; i < candidates.length; i++) {\\n            path.add(candidates[i]);\\n            backtrack(candidates,i,target,sum+candidates[i],path,result);\\n            path.remove(path.size()-1);\\n        }\\n\\n    }\\n}","compare_result":"1111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"combination-sum","has_notes":false,"flag_type":1,"frontend_id":804},{"id":2040646449,"question_id":77,"lang":"java","lang_name":"Java","time":"1\xc2\xa0week, 6\xc2\xa0days","timestamp":1782022728,"status":10,"status_display":"Accepted","runtime":"29 ms","url":"/submissions/detail/2040646449/","is_pending":"Not Pending","title":"Combinations","memory":"98.1 MB","code":"class Solution {\\n    public List<List<Integer>> combine(int n, int k) {\\n        List<List<Integer>> result = new ArrayList<>();\\n        List<Integer> path = new ArrayList<>();\\n        backtracking(1,n,path,result,k);\\n        return result;\\n    }\\n\\n    public void backtracking(int start, int end, List<Integer> path, List<List<Integer>> result, int k){\\n        if(path.size() == k){\\n            result.add(new ArrayList<>(path));\\n        }\\n\\n        for(int i = start; i<=end; i++){\\n            path.add(i);\\n            backtracking(i+1,end,path,result,k);\\n            path.remove(path.size()-1);\\n        }\\n    }\\n}","compare_result":"111111111111111111111111111","title_slug":"combinations","has_notes":false,"flag_type":1,"frontend_id":803},{"id":2040633123,"question_id":78,"lang":"java","lang_name":"Java","time":"1\xc2\xa0week, 6\xc2\xa0days","timestamp":1782021971,"status":10,"status_display":"Accepted","runtime":"1 ms","url":"/submissions/detail/2040633123/","is_pending":"Not Pending","title":"Subsets","memory":"44.1 MB","code":"class Solution {\\n    public List<List<Integer>> subsets(int[] nums) {\\n        List<List<Integer>> result = new ArrayList<>();\\n        List<Integer> path = new ArrayList<>();\\n\\n        backtrack(nums,0,path,result);\\n\\n        return result;\\n\\n    }\\n\\n    public void backtrack(int[] nums, int start, List<Integer> path,List<List<Integer>> result){\\n        result.add(new ArrayList<>(path));\\n\\n        for(int i = start; i<nums.length; i++){\\n            path.add(nums[i]);\\n            backtrack(nums,i+1,path,result);\\n            path.remove(path.size() - 1);\\n        }\\n       \\n    }\\n}","compare_result":"1111111111","title_slug":"subsets","has_notes":false,"flag_type":1,"frontend_id":802},{"id":2039737438,"question_id":23,"lang":"java","lang_name":"Java","time":"1\xc2\xa0week, 6\xc2\xa0days","timestamp":1781957521,"status":10,"status_display":"Accepted","runtime":"83 ms","url":"/submissions/detail/2039737438/","is_pending":"Not Pending","title":"Merge k Sorted Lists","memory":"46.7 MB","code":"/**\\n * Definition for singly-linked list.\\n * public class ListNode {\\n *     int val;\\n *     ListNode next;\\n *     ListNode() {}\\n *     ListNode(int val) { this.val = val; }\\n *     ListNode(int val, ListNode next) { this.val = val; this.next = next; }\\n * }\\n */\\nclass Solution {\\n    public ListNode mergeKLists(ListNode[] lists) {\\n        ListNode result = null;\\n\\n        for (ListNode list : lists) {\\n            result = merge(result, list);\\n        }\\n        return result;\\n    }\\n\\n    public ListNode merge(ListNode list1, ListNode list2) {\\n        if (list1 == null) {\\n            return list2;\\n        } else if(list2 == null){\\n            return list1;\\n        }\\n\\n        ListNode curr = (list1.val <= list2.val ? list1 : list2);\\n        ListNode head = curr;\\n\\n        if (curr == list1) {\\n            list1 = list1.next;\\n        } else {\\n            list2 = list2.next;\\n        }\\n        while (list1 != null && list2 != null) {\\n            if (list1.val <= list2.val) {\\n                curr.next = list1;\\n                list1 = list1.next;\\n            } else {\\n                curr.next = list2;\\n                list2 = list2.next;\\n            }\\n            curr = curr.next;\\n        }\\n        curr.next = list1 == null ? list2 : list1;\\n        return head;\\n    }\\n}","compare_result":"11111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"merge-k-sorted-lists","has_notes":false,"flag_type":1,"frontend_id":801},{"id":2039727816,"question_id":143,"lang":"java","lang_name":"Java","time":"1\xc2\xa0week, 6\xc2\xa0days","timestamp":1781956794,"status":10,"status_display":"Accepted","runtime":"1 ms","url":"/submissions/detail/2039727816/","is_pending":"Not Pending","title":"Reorder List","memory":"49 MB","code":"/**\\n * Definition for singly-linked list.\\n * public class ListNode {\\n *     int val;\\n *     ListNode next;\\n *     ListNode() {}\\n *     ListNode(int val) { this.val = val; }\\n *     ListNode(int val, ListNode next) { this.val = val; this.next = next; }\\n * }\\n */\\nclass Solution {\\n    public void reorderList(ListNode head) {\\n        ListNode slow = head;\\n        ListNode fast = head;\\n        while(fast.next!=null && fast.next.next!=null){\\n            slow = slow.next;\\n            fast = fast.next.next;\\n        }\\n\\n        ListNode prev = null;\\n        ListNode curr = slow.next;\\n        while(curr!=null){\\n            ListNode next = curr.next;\\n            curr.next = prev;\\n            prev = curr;\\n            curr = next;\\n        }\\n        slow.next = null;\\n        ListNode left = head;\\n        ListNode right = prev;\\n        \\n        while(right!=null){\\n            ListNode nxt1 = left.next;\\n            left.next = right;\\n            left = nxt1;\\n            ListNode nxt2 = right.next;\\n            right.next = left;\\n            right = nxt2;\\n        }   \\n    }\\n}","compare_result":"111111111111","title_slug":"reorder-list","has_notes":false,"flag_type":1,"frontend_id":800},{"id":2039327349,"question_id":682,"lang":"java","lang_name":"Java","time":"2\xc2\xa0weeks","timestamp":1781930553,"status":10,"status_display":"Accepted","runtime":"1 ms","url":"/submissions/detail/2039327349/","is_pending":"Not Pending","title":"Baseball Game","memory":"43.2 MB","code":"class Solution {\\n    public int calPoints(String[] operations) {\\n        int[] ans = new int[operations.length];\\n        int curr = 0;\\n        int sum = 0;\\n        for(int i = 0; i<operations.length; i++){\\n            if(operations[i].equals(\\"+\\")){\\n                ans[curr] = ans[curr-2]+ans[curr-1];\\n                curr++;\\n            }else if(operations[i].equals(\\"C\\")){\\n                ans[curr-1] = 0;\\n                curr--;\\n            }else if(operations[i].equals(\\"D\\")){\\n                ans[curr] = 2*ans[curr-1];\\n                curr++;\\n            }else{\\n                ans[curr] = Integer.parseInt(operations[i]);\\n                curr++;\\n            }\\n        }\\n        for(int num : ans){sum += num;}\\n        return sum;\\n    }\\n}","compare_result":"111111111111111111111111111111111111111","title_slug":"baseball-game","has_notes":false,"flag_type":1,"frontend_id":799}],"has_next":true,"last_key":""}'
