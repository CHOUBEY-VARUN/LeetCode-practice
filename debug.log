dingWindow(int[] nums, int k) {\\n        int[] ans = new int[nums.length - k + 1];\\n        Deque<Integer> q = new ArrayDeque<>();\\n        int idx = 0;\\n        for(int i = 0; i<nums.length; i++){\\n            while(!q.isEmpty() && nums[q.peekLast()]<nums[i]){\\n                q.removeLast();\\n            }\\n            while(!q.isEmpty() && q.peekFirst() <= i-k){\\n                q.removeFirst();\\n            }\\n            q.addLast(i);\\n            if(i >= k-1){\\n                ans[idx] = nums[q.peekFirst()];\\n                idx++;\\n            }\\n        }\\n\\n        return ans;\\n    }\\n}","compare_result":"1111111111111111111111111111111111111111111111111111","title_slug":"sliding-window-maximum","has_notes":false,"flag_type":1,"frontend_id":309},{"id":1839835041,"question_id":239,"lang":"java","lang_name":"Java","time":"7\xc2\xa0months, 1\xc2\xa0week","timestamp":1764117848,"status":11,"status_display":"Wrong Answer","runtime":"N/A","url":"/submissions/detail/1839835041/","is_pending":"Not Pending","title":"Sliding Window Maximum","memory":"N/A","code":"class Solution {\\n    public int[] maxSlidingWindow(int[] nums, int k) {\\n        int[] ans = new int[nums.length - k + 1];\\n        Deque<Integer> q = new ArrayDeque<>();\\n        int idx = 0;\\n        for(int i = 0; i<nums.length; i++){\\n            while(!q.isEmpty() && q.peekLast()<nums[i]){\\n                q.removeLast();\\n            }\\n            while(!q.isEmpty() && q.peekFirst() <= i-k){\\n                q.removeFirst();\\n            }\\n            q.addLast(i);\\n            if(i >= k-1){\\n                ans[idx] = nums[q.peekFirst()];\\n                idx++;\\n            }\\n        }\\n\\n        return ans;\\n    }\\n}","compare_result":"1111101011100000000000000000000000000000000000000000","title_slug":"sliding-window-maximum","has_notes":false,"flag_type":1,"frontend_id":308},{"id":1839834770,"question_id":239,"lang":"java","lang_name":"Java","time":"7\xc