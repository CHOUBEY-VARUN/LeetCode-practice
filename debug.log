g","title":"Count Prefix and Suffix Pairs I","memory":"43.8 MB","code":"class Solution {\\n    public int countPrefixSuffixPairs(String[] words) {\\n        int count = 0;\\n        \\n        for(int i = 0; i<words.length-1; i++){\\n            for(int j = i+1; j<words.length; j++){\\n                if(words[j].startsWith(words[i]) && words[j].endsWith(words[i]) ){\\n                    count++;\\n                }\\n            }\\n        }\\n        return count;\\n    }\\n}","compare_result":"","title_slug":"count-prefix-and-suffix-pairs-i","has_notes":false,"flag_type":1,"frontend_id":707},{"id":1984026775,"question_id":4115,"lang":"java","lang_name":"Java","time":"2\xc2\xa0months, 1\xc2\xa0week","timestamp":1776732154,"status":10,"status_display":"Accepted","runtime":"7 ms","url":"/submissions/detail/1984026775/","is_pending":"Not Pending","title":"Minimum Distance Between Three Equal Elements I","memory":"44.3 MB","code":"class Solution {\\n    public int minimumDistance(int[] nums) {\\n        if(nums.length<3)return -1;\\n        int result = Integer.MAX_VALUE;\\n        for(int i = 0; i<nums.length; i++){\\n            for(int j = i+1; j<nums.length; j++){\\n                for(int k = j+1; k<nums.length; k++){\\n                    if(nums[i]==nums[j] && nums[j]==nums[k]){\\n                        result = Math.min(result,Math.abs(Math.abs(i - j) + Math.abs(j - k) + Math.abs(k - i)));\\n                    }\\n                }\\n            }\\n        }\\n        return (result == Integer.MAX_VALUE) ? -1 : result;\\n    }\\n}","compare_result":"","title_slug":"minimum-distance-between-three-equal-elements-i","has_notes":false,"flag_type":1,"frontend_id":706},{"id":1984026280,"question_id":4115,"lang":"java","lang_name":"Java","time":"2\xc2\xa0months, 1\xc2\xa0week","timestamp":1776732054,"status":11,"status_display":"Wrong Answer","runtime":"N/A","url":"/submissions/detail/1984026280/","is_pending":"Not Pending","title":"Minimum Distance Between Thre