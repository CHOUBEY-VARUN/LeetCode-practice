     {\\n            if (freqAr[i] == null) continue;\\n            for (int j = 0; j < freqAr[i].size(); j++)\\n             {\\n                res[t++] = freqAr[i].get(j);\\n                if (t == k) \\n                {\\n                    return res;\\n                }\\n            }\\n        } \\n        return res;\\n    }\\n}","compare_result":"11111111111111111111111","title_slug":"top-k-frequent-elements","has_notes":false,"flag_type":1,"frontend_id":146},{"id":1818563836,"question_id":347,"lang":"java","lang_name":"Java","time":"8\xc2\xa0months","timestamp":1762082075,"status":10,"status_display":"Accepted","runtime":"16 ms","url":"/submissions/detail/1818563836/","is_pending":"Not Pending","title":"Top K Frequent Elements","memory":"47.6 MB","code":"class Solution {\\n    public int[] topKFrequent(int[] nums, int k) {\\n        Map<Integer,Integer> map = new HashMap<>();\\n        for(int n : nums){\\n            map.put(n,map.getOrDefault(n,0)+1);\\n        }\\n\\n        PriorityQueue<Integer> q = new PriorityQueue<>((a,b)->map.get(a)-map.get(b));\\n\\n        for(int n : map.keySet()){\\n            q.add(n);\\n            if(q.size()>k){\\n            q.poll();\\n            }\\n        }\\n\\n        int[] ans = new int[k];\\n        for(int i = 0; i<k; i++){\\n            ans[i] = q.poll();\\n        }\\n        return ans;\\n    }\\n}\\n","compare_result":"11111111111111111111111","title_slug":"top-k-frequent-elements","has_notes":false,"flag_type":1,"frontend_id":145},{"id":1818562742,"question_id":347,"lang":"java","lang_name":"Java","time":"8\xc2\xa0months","timestamp":1762081971,"status":10,"status_display":"Accepted","runtime":"15 ms","url":"/submissions/detail/1818562742/","is_pending":"Not Pending","title":"Top K Frequent Elements","memory":"47.4 MB","code":"class Solution {\\n    public int[] topKFrequent(int[] nums, int k) {\\n        Map<Integer,Integer> map = new HashMap<>();\\n        for(int n : nums){\\n            map.put(n, 