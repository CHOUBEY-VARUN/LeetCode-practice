.add(n);\\n            if(q.size()>k){q.poll();}\\n        }\\n        int[] ans = new int[k];\\n        for(int i = 0; i<k; i++){\\n            ans[i] = q.poll();\\n        }\\n        return ans;\\n    }\\n}","compare_result":"11111111111111111111111","title_slug":"top-k-frequent-elements","has_notes":false,"flag_type":1,"frontend_id":85},{"id":1813645021,"question_id":215,"lang":"java","lang_name":"Java","time":"8\xc2\xa0months","timestamp":1761621146,"status":10,"status_display":"Accepted","runtime":"63 ms","url":"/submissions/detail/1813645021/","is_pending":"Not Pending","title":"Kth Largest Element in an Array","memory":"61.5 MB","code":"class Solution {\\n    public int findKthLargest(int[] nums, int k) {\\n        PriorityQueue<Integer> q = new PriorityQueue();\\n        for(int n:nums){\\n            q.add(n);\\n            if(q.size()>k){q.poll();}\\n        }\\n        return q.poll();\\n    }\\n}","compare_result":"11111111111111111111111111111111111111111111","title_slug":"kth-largest-element-in-an-array","has_notes":null,"flag_type":1,"frontend_id":84},{"id":1813588312,"question_id":347,"lang":"java","lang_name":"Java","time":"8\xc2\xa0months","timestamp":1761614307,"status":10,"status_display":"Accepted","runtime":"18 ms","url":"/submissions/detail/1813588312/","is_pending":"Not Pending","title":"Top K Frequent Elements","memory":"48.5 MB","code":"class Solution {\\n    public int[] topKFrequent(int[] nums, int k) {\\n        Map<Integer,Integer> map = new HashMap<>();\\n        for(int n : nums){\\n            if(!map.containsKey(n)){\\n                map.put(n,1);\\n            }\\n            map.put(n,map.getOrDefault(n,0)+1);\\n        }\\n         List<Map.Entry<Integer, Integer>> list = new ArrayList<> (map.entrySet());\\n        list.sort((a,b)->b.getValue()-a.getValue());\\n        int[] ans = new int[k];\\n        for(int i = 0; i<k; i++){\\n            ans[i] = list.get(i).getKey();\\n        }\\n        return ans;\\n    }\\n}","compare_result":"11111111111111111111111","title_slug":"top-k-frequent-elements","has_notes":null,"flag_type":1,"frontend_id":83},{"id":1812714343,"question_id":238,"lang":"java","lang_name":"Java","time":"8\xc2\xa0months, 1\xc2\xa0week","timestamp":1761530502,"status":10,"status_display":"Accepted","runtime":"2 ms","url":"/submissions/detail/1812714343/","is_pending":"Not Pending","title":"Product of Array Except Self","memory":"55.2 MB","code":"class Solution {\\n    public int[] productExceptSelf(int[] nums) {\\n        int zeroes = 0;\\n        int product = 1;\\n        int[] ans = new int[nums.length];\\n        for(int n : nums){\\n            if(n!=0){product *= n;}else{zeroes++;}\\n        }\\n        if(zeroes>1)return new int[nums.length];\\n        if(zeroes==1){\\n            for(int i = 0; i<nums.length; i++){\\n                if(nums[i]==0)ans[i] = product;\\n                }\\n        }\\n\\n        if(zeroes<1){\\n            for(int i = 0; i<nums.length; i++){\\n                ans[i] = product/nums[i];\\n            }\\n        }\\n        return ans;\\n    }\\n}","compare_result":"111111111111111111111111","title_slug":"product-of-array-except-self","has_notes":false,"flag_type":1,"frontend_id":82},{"id":1812706044,"question_id":242,"lang":"java","lang_name":"Java","time":"8\xc2\xa0months, 1\xc2\xa0week","timestamp":1761529388,"status":10,"status_display":"Accepted","runtime":"4 ms","url":"/submissions/detail/1812706044/","is_pending":"Not Pending","title":"Valid Anagram","memory":"44.9 MB","code":"class Solution {\\n    public boolean isAnagram(String s, String t) {\\n        char[] ch1 = s.toCharArray();\\n        char[] ch2 = t.toCharArray();\\n        Arrays.sort(ch1);\\n        Arrays.sort(ch2);\\n        return Arrays.equals(ch1,ch2);\\n    }\\n}","compare_result":"11111111111111111111111111111111111111111111111111111","title_slug":"valid-anagram","has_notes":null,"flag_type":1,"frontend_id":81},{"id":1812687311,"question_id":242,"lang":"java","lang_name":"Java","time":"8\xc2\xa0months, 1\xc2\xa0week","timestamp":1761526817,"status":10,"status_display":"Accepted","runtime":"14 ms","url":"/submissions/detail/1812687311/","is_pending":"Not Pending","title":"Valid Anagram","memory":"44.9 MB","code":"class Solution {\\n    public boolean isAnagram(String s, String t) {\\n        if(s.length()!=t.length()){return false;}\\n        Map<Character,Integer> map = new HashMap<>();\\n\\n        for(char c : s.toCharArray()){\\n            map.put(c,map.getOrDefault(c,0)+1);\\n        }\\n        \\n        for(char c : t.toCharArray()){\\n            if(!map.containsKey(c))return false;\\n            map.put(c,map.getOrDefault(c,0)-1);\\n            if(map.get(c)<1)map.remove(c);\\n        }\\n        return true;\\n    }\\n}","compare_result":"11111111111111111111111111111111111111111111111111111","title_slug":"valid-anagram","has_notes":false,"flag_type":1,"frontend_id":80},{"id":1812683075,"question_id":242,"lang":"java","lang_name":"Java","time":"8\xc2\xa0months, 1\xc2\xa0week","timestamp":1761526228,"status":11,"status_display":"Wrong Answer","runtime":"N/A","url":"/submissions/detail/1812683075/","is_pending":"Not Pending","title":"Valid Anagram","memory":"N/A","code":"class Solution {\\n    public boolean isAnagram(String s, String t) {\\n        if(s.length()!=t.length()){return false;}\\n        Set<Character> set1 = new HashSet<>();\\n        Set<Character> set2 = new HashSet<>();\\n        for(char c: s.toCharArray()){\\n            set1.add(c);\\n        }\\n        for(char c: t.toCharArray()){\\n            set2.add(c);\\n        }\\n        return set1.equals(set2);\\n    }\\n}","compare_result":"11111111111111111110111111011111111101001111111111111","title_slug":"valid-anagram","has_notes":false,"flag_type":1,"frontend_id":79}],"has_next":true,"last_key":""}'
