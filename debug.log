kLast()] <= nums[i]) {\\n                q.pollLast();\\n            }\\n            q.addLast(i);\\n\\n            if (i >= k - 1) {\\n\\n                ans[x] = nums[q.peekFirst()];\\n                x++;\\n\\n                if (q.peekFirst() == left) {\\n                    q.pollFirst();\\n                }\\n                left++;\\n            }\\n        }\\n        return ans;\\n    }\\n}","compare_result":"1111111111111111111111111111111111111111111111111111","title_slug":"sliding-window-maximum","has_notes":false,"flag_type":1,"frontend_id":783},{"id":2031336741,"question_id":121,"lang":"java","lang_name":"Java","time":"3\xc2\xa0weeks","timestamp":1781324172,"status":10,"status_display":"Accepted","runtime":"1 ms","url":"/submissions/detail/2031336741/","is_pending":"Not Pending","title":"Best Time to Buy and Sell Stock","memory":"94.6 MB","code":"class Solution {\\n    public int maxProfit(int[] prices) {\\n        int maxProfit = Integer.MIN_VALUE;\\n        int buy = 0;\\n        for(int sell = 0; sell<prices.length; sell++){\\n            if(prices[sell] < prices[buy]){\\n                buy = sell;\\n            }\\n            int profit = prices[sell] - prices[buy];\\n            maxProfit = Math.max(profit,maxProfit);\\n        }\\n        return maxProfit;\\n    }\\n}","compare_result":"11111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"best-time-to-buy-and-sell-stock","has_notes":null,"flag_type":3,"frontend_id":782},{"id":2025807252,"question_id":141,"lang":"java","lang_name":"Java","time":"3\xc2\xa0weeks, 5\xc2\xa0days","timestamp":1780881395,"status":10,"status_display":"Accepted","runtime":"0 ms","url":"/submissions/detail/2025807252/","is_pending":"Not Pending","title":"Linked List Cycle","memory":"46.7 MB","code":"/**\\n * Definition for singly-linked list.\\n * c