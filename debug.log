arArray()){map.put(c,map.getOrDefault(c,0)+1);}\\n        int left = 0, start = 0, counter = 0, need = t.length();\\n        int len = Integer.MAX_VALUE;\\n\\n        for(int right = 0; right<s.length(); right++){\\n            char c = s.charAt(right);\\n            if(map.containsKey(c)){\\n                if(map.get(c)>0)counter++;\\n                map.put(c,map.getOrDefault(c,0)-1);\\n            }\\n            while(counter == need){\\n                if(right - left + 1 < len){\\n                    len = right - left + 1;\\n                    start = left;\\n                }\\n                char l = s.charAt(left);\\n                if(map.containsKey(l)){\\n                    map.put(l,map.getOrDefault(l,0)+1);\\n                    if(map.get(l)>0)counter--;\\n                }\\n                left++;\\n            }\\n        }\\n        return len == Integer.MAX_VALUE ? \\"\\" : s.substring(start, start + len);\\n    }\\n}","compare_result":"1111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"minimum-window-substring","has_notes":false,"flag_type":1,"frontend_id":124},{"id":1817248074,"question_id":239,"lang":"java","lang_name":"Java","time":"8\xc2\xa0months","timestamp":1761955649,"status":10,"status_display":"Accepted","runtime":"29 ms","url":"/submissions/detail/1817248074/","is_pending":"Not Pending","title":"Sliding Window Maximum","memory":"146.9 MB","code":"class Solution {\\n    public int[] maxSlidingWindow(int[] nums, int k) {\\n        Deque<Integer> q = new ArrayDeque<>();\\n        int[] ans = new int[nums.length - k + 1];\\n        for(int i = 0; i<nums.length; i++){\\n            while(!q.isEmpty() && q.peekFirst() <= i-k)q.removeFirst();\\n            while(!q.isEmpty() && nums[q.peekLast()] < nums[i]){