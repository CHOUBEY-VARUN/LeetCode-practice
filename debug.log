eft = left;\\n *         this.right = right;\\n *     }\\n * }\\n */\\nclass Solution {\\n    public TreeNode invertTree(TreeNode root) {\\n        if(root==null)return null;\\n\\n        swap(root);\\n        invertTree(root.left);\\n        invertTree(root.right);\\n\\n        return root;\\n    }\\n\\n    public void swap(TreeNode root){\\n        TreeNode node = root.left;\\n        root.left = root.right;\\n        root.right = node;\\n    }\\n}","compare_result":"11111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"invert-binary-tree","has_notes":false,"flag_type":1,"frontend_id":815},{"id":2045391690,"question_id":212,"lang":"java","lang_name":"Java","time":"1\xc2\xa0week, 2\xc2\xa0days","timestamp":1782368226,"status":14,"status_display":"Time Limit Exceeded","runtime":"N/A","url":"/submissions/detail/2045391690/","is_pending":"Not Pending","title":"Word Search II","memory":"N/A","code":"class Solution {\\n    public List<String> findWords(char[][] board, String[] words) {\\n        List<String> result = new ArrayList<>();\\n        for (String word : words) {\\n            Boolean found = false;\\n            for (int row = 0; row < board.length; row++) {\\n                if(found)break;\\n                for (int col = 0; col < board[0].length; col++) {\\n                    if (finder(board, word, row, col, 0)) {\\n                        result.add(word);\\n                        found = true;\\n                        break;\\n                    }\\n                }\\n            }\\n        }\\n        return result;\\n    }\\n\\n    public Boolean finder(char[][] board, String word, int row, int col, int idx) {\\n        if (idx >= word.length())\\n            return true;\\n        if (row < 0 || row >= board.length || col < 0 || col >= board[0].length || board[row][col] != word.charAt(idx))\\n            return false;\\n\\n        char letter = board[row][col];\\n        board[row][col] = \' \';\\n        