        if(nums[i] == 0){res[i] = product;}\\n                }\\n                }else if(zeroes < 1){\\n                    for(int i = 0; i<nums.length; i++){\\n                        res[i] = product/nums[i];\\n                    }\\n                }\\n            return res;\\n            }\\n    }\\n","compare_result":"111111111111111111111111","title_slug":"product-of-array-except-self","has_notes":false,"flag_type":1,"frontend_id":365},{"id":1851572110,"question_id":49,"lang":"java","lang_name":"Java","time":"6\xc2\xa0months, 3\xc2\xa0weeks","timestamp":1765331376,"status":10,"status_display":"Accepted","runtime":"6 ms","url":"/submissions/detail/1851572110/","is_pending":"Not Pending","title":"Group Anagrams","memory":"49.3 MB","code":"class Solution {\\n    public List<List<String>> groupAnagrams(String[] strs) {\\n        List<String> list = new ArrayList<>();\\n        Map<String,List<String>> map = new HashMap<>();\\n        for(String s : strs){\\n            char[] ch = s.toCharArray();\\n            Arrays.sort(ch);\\n            String sorted = new String(ch);\\n            if(!map.containsKey(sorted)){\\n                map.put(sorted,new ArrayList<>());\\n                }\\n                map.get(sorted).add(s);\\n        }\\n        return new ArrayList<>(map.values());\\n    }\\n}","compare_result":"11111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"group-anagrams","has_notes":false,"flag_type":1,"frontend_id":364},{"id":1851561912,"question_id":242,"lang":"java","lang_name":"Java","time":"6\xc2\xa0months, 3\xc2\xa0weeks","timestamp":1765329718,"status":10,"status_display":"Accepted","runtime":"13 ms","url":"/submissions/detail/1851561912/","is_pending":"Not Pending","title":"Valid Anagram","memory":"46.5 MB","code":"class Solution {\\n    public boolean isAnagram(String s, String t) {\\n        Map<Character,Integer> mapS = new HashMap<>();\\n        for(char c : s.toCharArray()){mapS.put(c,mapS.getOrDefault(c,0)+1);}\\n        Map<Character,Integer> mapT = new HashMap<>();\\n        for(char c : t.toCharArray()){mapT.put(c,mapT.getOrDefault(c,0)+1);}\\n        return mapS.equals(mapT);\\n    }\\n}","compare_result":"111111111111111111111111111111111111111111111111111111","title_slug":"valid-anagram","has_notes":false,"flag_type":1,"frontend_id":363},{"id":1850623461,"question_id":990,"lang":"java","lang_name":"Java","time":"6\xc2\xa0months, 3\xc2\xa0weeks","timestamp":1765244777,"status":10,"status_display":"Accepted","runtime":"1 ms","url":"/submissions/detail/1850623461/","is_pending":"Not Pending","title":"Verifying an Alien Dictionary","memory":"43.2 MB","code":"class Solution {\\n    public boolean isAlienSorted(String[] words, String order) {\\n        Map<Character,Integer> map = new HashMap<>();\\n        for(int i = 0; i<order.length(); i++){\\n            map.put(order.charAt(i),i);\\n        }\\n        \\n        for(int i = 0; i<words.length - 1; i++){\\n            String a = words[i];\\n            String b = words[i+1];\\n            int len = Math.min(a.length(),b.length());\\n            boolean ans = false;\\n            for(int j = 0; j<len; j++){\\n                if(map.get(a.charAt(j)) < map.get(b.charAt(j))){\\n                    ans = true; break;\\n                }else if(map.get(a.charAt(j)) > map.get(b.charAt(j))){\\n                    return false;\\n                }else{continue;}\\n            }\\n            if(ans == false && a.length() > b.length()){\\n                    return false;\\n            }\\n        }\\n        return true;\\n    }\\n}","compare_result":"11111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"verifying-an-alien-dictionary","has_notes":false,"flag_type":1,"frontend_id":362},{"id":1850622983,"question_id":990,"lang":"java","lang_name":"Java","time":"6\xc2\xa0mo