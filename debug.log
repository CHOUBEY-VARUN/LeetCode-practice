on {\\n    public int countSubstrings(String s) {\\n        int count = 0;\\n        for(int i = 0; i < s.length(); i++){\\n            count += check(s, i , i);\\n            count += check(s, i , i+1);\\n        }\\n        return count;\\n    }\\n    public int check(String s, int left, int right){\\n        int count = 0;\\n        while(left >= 0 && right<s.length() && s.charAt(left)==s.charAt(right)){\\n            count++;\\n            left--;\\n            right++;\\n        }\\n        return count;\\n    }\\n}","compare_result":"111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"palindromic-substrings","has_notes":false,"flag_type":1,"frontend_id":184},{"id":1823676030,"question_id":647,"lang":"java","lang_name":"Java","time":"7\xc2\xa0months, 3\xc2\xa0weeks","timestamp":1762560749,"status":20,"status_display":"Compile Error","runtime":"N/A","url":"/submissions/detail/1823676030/","is_pending":"Not Pending","title":"Palindromic Substrings","memory":"N/A","code":"class Solution {\\n    public int countSubstrings(String s) {\\n        int count = 0;\\n        for(int i = 0; i<s.length(); i++){\\n            char curr = s.charAt(i);\\n            count++;\\n            if(i>0 && i<s.length-1){\\n                char left = s.charAt(i-1);\\n                char right = s.charAt(i+1);\\n                while(left == right){\\n                    count++;\\n                    left++;\\n                    right--;\\n                }\\n            }\\n        }\\n    }\\n}","compare_result":null,"title_slug":"palindromic-substrings","has_notes":false,"flag_type":1,"frontend_id":183},{"id":1823676021,"question_id":647,"lang":"java","lang_name":"Java","time":"7\xc2\xa0months, 3\xc2\xa0weeks","timestamp":1762560747,"status":20,"status_display":"Compile Error","runtime":"N/A","url":"/submissions/detail/1823676021/","is_pending":"Not Pending","title":"Palindromic Substr