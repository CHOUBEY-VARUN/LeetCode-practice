\\n            }else{\\n                currSum = nums[i];\\n                maxSum = Math.max(maxSum,currSum);\\n            }\\n        }\\n        return maxSum;\\n    }\\n}","compare_result":"111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"maximum-subarray","has_notes":false,"flag_type":1,"frontend_id":302},{"id":1839063477,"question_id":1849,"lang":"java","lang_name":"Java","time":"7\xc2\xa0months, 1\xc2\xa0week","timestamp":1764044634,"status":10,"status_display":"Accepted","runtime":"3 ms","url":"/submissions/detail/1839063477/","is_pending":"Not Pending","title":"Maximum Absolute Sum of Any Subarray","memory":"66.8 MB","code":"class Solution {\\n    public int maxAbsoluteSum(int[] nums) {\\n        int currSum = 0;\\n        int maxSum = 0;\\n        for(int n : nums){\\n            if(currSum + n > n){\\n                currSum += n;\\n                maxSum = Math.max(maxSum,currSum);\\n            }else{\\n                currSum = n;\\n                maxSum = Math.max(maxSum,currSum);\\n            }\\n        }\\n\\n        currSum = 0;\\n        int minSum = 0;\\n        for(int n : nums){\\n            if(currSum + n < n){\\n                currSum +=n;\\n                minSum = Math.min(minSum,currSum);\\n            }else{\\n                currSum = n;\\n                minSum = Math.min(minSum,currSum);\\n            }\\n        }\\n\\n        return Math.max(Math.abs(minSum),maxSum);\\n    }\\n}","compare_result":"1111111111111111111111111111111111111111111111111111111111111111111","title_slug":"maximum-absolute-sum-of-any-subarray","has_notes":null,"flag_type":1,"frontend_id":301},{"id":1838982456,"question_id":3,"lang":"java","lang_name":"Java","time":"7\xc2\xa0months, 1\xc2\xa0week","timestamp":1764035088,"status":10,"status_display":"Accepted","runtime":"7 ms","url":"/submissions/detail/1838982456/","is_pending":"Not Pending","title":"Longest Substring Without Repeating Characters","memory":"46.7 MB","code":"class Solution {\\n    public int lengthOfLongestSubstring(String s) {\\n        Set<Character> set = new HashSet<>();\\n        int left = 0;\\n        int maxLen = 0;\\n        for(int right = 0; right < s.length(); right++){\\n            char curr = s.charAt(right);\\n            if(!set.contains(curr)){\\n                set.add(curr);\\n                maxLen = Math.max(maxLen,set.size());\\n            }else{\\n                while(set.contains(curr)){\\n                    set.remove(s.charAt(left));\\n                    left++;\\n                }\\n                set.add(curr);\\n                maxLen = Math.max(maxLen,set.size());\\n            }\\n        }\\n        return maxLen;\\n    }\\n}","compare_result":"","title_slug":"longest-substring-without-repeating-characters","has_notes":false,"flag_type":1,"frontend_id":300},{"id":1838251482,"question_id":121,"lang":"java","lang_name":"Java","time":"7\xc2\xa0months, 1\xc2\xa0week","timestamp":1763964899,"status":10,"status_display":"Accepted","runtime":"2 ms","url":"/submissions/detail/1838251482/","is_pending":"Not Pending","title":"Best Time to Buy and Sell Stock","memory":"94.5 MB","code":"class Solution {\\n    public int maxProfit(int[] prices) {\\n        int max = 0; int min = prices[0];\\n        for(int i = 1; i<prices.length; i++){\\n            min = Math.min(min, prices[i]);\\n            int profit = prices[i] - min;\\n            if(profit > max){\\n                max = profit;\\n            }\\n        }\\n        return max;\\n    }\\n}","compare_result":"11111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"best-time-to-buy-and-sell-stock","has_notes":false,"flag_type":1,"frontend_id":299}],"has_next":true,"last_key":""}'
