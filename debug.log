nt[] nums, int k) {\\n        int[] result = new int[k];\\n        Map<Integer,Integer> map = new HashMap<>();\\n        for(int i : nums){\\n            map.put(i,map.getOrDefault(i,0)+1);\\n        }\\n        PriorityQueue<Integer> pq = new PriorityQueue<>((a,b)->map.get(b)-map.get(a));\\n        for(int key: map.keySet()){\\n            pq.add(key);\\n        }\\n    \\n        for(int i = 0; i<k; i++){\\n            result[i] = pq.poll();\\n        }\\n        return result;\\n    }\\n}","compare_result":"11111111111111111111111","title_slug":"top-k-frequent-elements","has_notes":false,"flag_type":1,"frontend_id":190},{"id":1824588768,"question_id":26,"lang":"java","lang_name":"Java","time":"7\xc2\xa0months, 3\xc2\xa0weeks","timestamp":1762651184,"status":10,"status_display":"Accepted","runtime":"1 ms","url":"/submissions/detail/1824588768/","is_pending":"Not Pending","title":"Remove Duplicates from Sorted Array","memory":"46.9 MB","code":"class Solution {\\n    public int removeDuplicates(int[] nums) {\\n        int index = 0;\\n        for(int i = 0; i<nums.length; i++){\\n            if(nums[i]==nums[index])continue;\\n            nums[index+1] = nums[i];\\n            index++;\\n        }\\n        return index+1;\\n    }\\n}","compare_result":"","title_slug":"remove-duplicates-from-sorted-array","has_notes":false,"flag_type":1,"frontend_id":189},{"id":1824580775,"question_id":68,"lang":"java","lang_name":"Java","time":"7\xc2\xa0months, 3\xc2\xa0weeks","timestamp":1762649820,"status":20,"status_display":"Compile Error","runtime":"N/A","url":"/submissions/detail/1824580775/","is_pending":"Not Pending","title":"Text Justification","memory":"N/A","code":"class Solution {\\n    public List<String> fullJustify(String[] words, int maxWidth) {\\n        List<String> result = new ArrayList<>();\\n        int i = 0;\\n        while(i < words.length){\\n            int j = i;\\n            int len = 0;\\n            while(j<words.length && len + words[j].length + (j-